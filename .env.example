# IPA Project Configuration Template
# Copy to .env and fill in your values: cp .env.example .env
#
# AWS_PROFILE      — AWS CLI profile name (optional — omit line to use default credential chain)
# AWS_REGION       — AWS region for deployments (e.g., us-east-1)
# AWS_ACCOUNT_ID   — 12-digit AWS account ID (auto-detected if AWS CLI available)
# APP_NAMESPACE    — Project name prefix for stack naming (max 12 chars,
#                    lowercase alphanumeric + hyphens, starts with letter)
# APP_ENV          — Environment label (e.g., dev, stage, prod)
# APP_CODE_AGENT   — AI agent platform (auto-set, do not change)
# APP_IAC          — Infrastructure-as-code tool (cloudformation or terraform)

# AWS_PROFILE=your-profile-name
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=000000000000
APP_NAMESPACE=myproject
APP_ENV=dev
APP_CODE_AGENT=claude-code
APP_IAC=cloudformation

# Terraform State Backend (populated after tfstate deploy)
# Only relevant when APP_IAC=terraform
# TF_STATE_BUCKET=
# TF_STATE_LOCK_TABLE=

# IPA Security Configuration (populated after security deploy)
# APP_BUILDER_ROLE_ARN    — IAM role ARN for local deployments
# APP_CODEBUILD_ROLE_ARN  — IAM role ARN for CI/CD deployments
# APP_KMS_KEY_ARN         — Optional KMS key ARN for encryption at rest
APP_BUILDER_ROLE_ARN=arn:aws:iam::000000000000:role/myproject-dev-builder
APP_CODEBUILD_ROLE_ARN=arn:aws:iam::000000000000:role/myproject-dev-codebuild
# APP_KMS_KEY_ARN=arn:aws:kms:us-east-1:000000000000:key/00000000-0000-0000-0000-000000000000

# OIDC Configuration (populated after cognito deploy)
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_DISCOVERY_URL=
# OIDC_END_SESSION_ENDPOINT=
# OIDC_USER_POOL_ID=

# ECR Configuration (populated after ecr deploy)
# ECR_REPO_URI=

# SQS Configuration (populated after queue deploy)
# SQS_QUEUE_URL=

# Pipeline Configuration (populated after codepipeline deploy)
# PIPELINE_STACK_NAME      — CodePipeline CloudFormation stack name
# PIPELINE_NAME            — CodePipeline pipeline name
# CODEBUILD_PROJECT_NAME   — CodeBuild project name
# CODECOMMIT_STACK_NAME    — CodeCommit CloudFormation stack name
# CODECOMMIT_REPO_NAME     — CodeCommit repository name
# CODECOMMIT_CLONE_URL     — HTTPS clone URL for pushing code
# PIPELINE_STACK_NAME=myproject-dev-codepipeline
# PIPELINE_NAME=myproject-dev-pipeline
# CODEBUILD_PROJECT_NAME=myproject-dev-build
# CODECOMMIT_STACK_NAME=myproject-dev-codecommit
# CODECOMMIT_REPO_NAME=myproject-dev-repo
# CODECOMMIT_CLONE_URL=https://git-codecommit.us-east-1.amazonaws.com/v1/repos/myproject-dev-repo
