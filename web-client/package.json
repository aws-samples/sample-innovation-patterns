{
  "name": "web-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "prettier --write \"src/**/*.{ts,tsx,css}\" && eslint . --fix",
    "lint:cicd": "prettier --check \"src/**/*.{ts,tsx,css}\" && eslint .",
    "lint:cicd:junit": "eslint . -f node_modules/@crowdstrike/eslint-junit/index.js -o lint-eslint.xml; prettier --check \"src/**/*.{ts,tsx,css}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "postinstall": "cp node_modules/@axa-fr/oidc-client-service-worker/dist/OidcServiceWorker.js public/OidcServiceWorker.js",
    "preview": "vite preview",
    "update:openapi": "curl -o openapi-schema.json http://localhost:8000/openapi.json",
    "generate:api": "npx @rtk-query/codegen-openapi openapi-config.cjs",
    "codegen": "npm run update:openapi && npm run generate:api",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.12",
    "@assistant-ui/react-markdown": "^0.12.5",
    "@axa-fr/react-oidc": "^7.26.7",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@tabler/icons-react": "^3.37.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-table": "^8.21.3",
    "@types/nprogress": "^0.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "eventsource": "^4.1.0",
    "highlight.js": "^11.11.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "nprogress": "^0.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-feature-flags": "^1.0.0",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-resizable-panels": "^4.8.0",
    "react-router": "^7.13.1",
    "recharts": "^2.15.4",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@crowdstrike/eslint-junit": "^1.0.0",
    "@eslint/js": "^9.39.1",
    "@rtk-query/codegen-openapi": "^2.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "msw": "^2.13.2",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "hono": "^4.12.14"
  }
}
