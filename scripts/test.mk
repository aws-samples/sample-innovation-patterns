# Test targets for react-rest-lambda + sqs-lambda pattern
# Generated by /ipa.compose — do not edit manually
#
# Usage:
#   make -f scripts/test.mk test              # lint + test everything
#   make -f scripts/test.mk test-web          # web-client lint + unit tests
#   make -f scripts/test.mk test-app          # app-lib lint + unit tests
#   make -f scripts/test.mk test-web-cov      # web-client tests with coverage

-include .env

.PHONY: test lint-web lint-app test-web test-web-watch test-web-cov test-app

# Run all linting and tests
test: test-web test-app

# ── Web Client ──────────────────────────────────────────────

# Lint check (no modifications — CI-safe)
lint-web:
	cd web-client && npm run lint:cicd

# Lint then test
test-web: lint-web
	cd web-client && npm test

test-web-watch:
	cd web-client && npm run test:watch

test-web-cov: lint-web
	cd web-client && npm run test:coverage

# ── App Library ─────────────────────────────────────────────

# Lint check (no modifications — CI-safe)
# Uses uv run to ensure ruff/pytest are available from the venv
lint-app:
	cd app-lib && uv run ruff check --quiet && uv run ruff format --check

# Lint then test
test-app: lint-app
	cd app-lib && uv run python -m pytest
