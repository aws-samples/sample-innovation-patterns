# === TEARDOWN (reverse order) ===

teardown: teardown-esm teardown-fn-worker teardown-cf teardown-s3 teardown-app-cloudwatch teardown-apigwv2 teardown-fn teardown-ddb-passengers teardown-ddb-jobs teardown-sqs

teardown-esm:
	aws cloudformation delete-stack \
		--stack-name $(APP_NAMESPACE)-$(APP_ENV)-esm
	aws cloudformation wait stack-delete-complete \
		--stack-name $(APP_NAMESPACE)-$(APP_ENV)-esm

teardown-fn-worker:
