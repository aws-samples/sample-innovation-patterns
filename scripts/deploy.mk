	$(eval S3_BUCKET_DOMAIN_NAME := $(shell aws cloudformation describe-stacks \
		--stack-name $(APP_NAMESPACE)-$(APP_ENV)-s3 \
		--query 'Stacks[0].Outputs[?OutputKey==`BucketDomainName`].OutputValue' \
