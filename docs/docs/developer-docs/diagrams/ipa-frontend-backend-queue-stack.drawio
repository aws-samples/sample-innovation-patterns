                <mxCell id="yeEFA4pjfnQ1RmNaF71k-81" value="&lt;h1&gt;Innovation Patterns - Frontend / Backend / Queue Stacks&lt;/h1&gt;&lt;div&gt;&lt;p style=&quot;text-align: justify;&quot; data-pm-slice=&quot;1 1 []&quot;&gt;This pattern deploys a full-stack application with a React+Vite frontend on CloudFront/S3 connected to a REST API on Lambda behind API Gateway. The backend runs a FastAPI application in a container image served through Lambda Web Adapter, with DynamoDB as the data store and Titanic passenger records as demo data. A Cognito user pool provides OIDC authentication across the stack. The frontend is built once and configured at deploy time with a runtime config.js file that injects the API Gateway URL and Cognito settings — no rebuild needed if endpoints change. CloudFront distributes the SPA with OAC-secured S3 origin access. The API Gateway exposes both buffered CRUD routes and an optional streaming Lambda for Server-Sent Events. The pattern combines three sub-patterns — REST Lambda, CloudFront web client, and Cognito — wired together through CloudFormation stack outputs.&lt;/p&gt;&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="eWvkzI7JA3mnsKtQmJyP-1" vertex="1">
                    <mxGeometry x="111" y="2188" width="932" height="151" as="geometry"/>
                </mxCell>
                <mxCell id="yeEFA4pjfnQ1RmNaF71k-83" value="&lt;b&gt;React Single Page Application&lt;/b&gt;&amp;nbsp;delivers the application functionality. Application is written using Vite and Redux Toolkit for state management." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" parent="eWvkzI7JA3mnsKtQmJyP-1" vertex="1">
                    <mxGeometry x="1764" y="2563" width="280" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="yeEFA4pjfnQ1RmNaF71k-84" value="&lt;b&gt;CloudFront&lt;/b&gt;&amp;nbsp;is the content delivery network, and delivers the app to edge endpoints for optimal performance worldwide." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" parent="eWvkzI7JA3mnsKtQmJyP-1" vertex="1">
                    <mxGeometry x="1764" y="2628" width="280" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="yeEFA4pjfnQ1RmNaF71k-85" value="&lt;b&gt;API Gateway &lt;/b&gt;fronts the application and handled load balancing and the first level of authorization.&amp;nbsp;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" parent="eWvkzI7JA3mnsKtQmJyP-1" vertex="1">
                    <mxGeometry x="1766" y="2704" width="280" height="62" as="geometry"/>
                </mxCell>
                <mxCell id="yeEFA4pjfnQ1RmNaF71k-86" value="&lt;b&gt;Cognito&lt;/b&gt;&amp;nbsp;serves as the identity provider. The app references the Cognito service using a standard OIDC implementation, ready to be swapped out for a customer&#39;s OIDC compliant IdP." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" parent="eWvkzI7JA3mnsKtQmJyP-1" vertex="1">
                    <mxGeometry x="1769" y="2766" width="280" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="yeEFA4pjfnQ1RmNaF71k-87" value="&lt;b&gt;Elastic Container Registry&lt;/b&gt;&amp;nbsp;holds container images for the container based Lambda compute." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" parent="eWvkzI7JA3mnsKtQmJyP-1" vertex="1">
                    <mxGeometry x="1768" y="2898" width="280" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="yeEFA4pjfnQ1RmNaF71k-88" value="&lt;b&gt;Python app-lib/&lt;/b&gt;&amp;nbsp;is a pyproject.toml based library that offers a FastAPI REST interface with CRUD methods." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" parent="eWvkzI7JA3mnsKtQmJyP-1" vertex="1">
                    <mxGeometry x="1766" y="2955" width="280" height="68" as="geometry"/>
                </mxCell>
                <mxCell id="yeEFA4pjfnQ1RmNaF71k-90" value="&lt;b&gt;Streaming Lambda&lt;/b&gt;&amp;nbsp;delivers SSE streaming methods for realtime client updates. The streaming lambda is also implemented using the Lambda Web Adapter." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" parent="eWvkzI7JA3mnsKtQmJyP-1" vertex="1">
                    <mxGeometry x="1764" y="3023" width="280" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="yeEFA4pjfnQ1RmNaF71k-91" value="&lt;b style=&quot;border-color: rgb(218, 220, 224);&quot;&gt;DynamoDB Table&lt;/b&gt;&amp;nbsp;holds system data. High performance and scalable. Simple and secure." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" parent="eWvkzI7JA3mnsKtQmJyP-1" vertex="1">
                    <mxGeometry x="1764" y="3105" width="280" height="82" as="geometry"/>
                </mxCell>
