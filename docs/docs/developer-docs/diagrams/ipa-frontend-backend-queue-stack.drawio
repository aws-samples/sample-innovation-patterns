                <mxCell id="WJwmBw8dlnYn9toBohla-2" value="&lt;b&gt;S3 Content Bucket&lt;/b&gt;&amp;nbsp;stores static web application files for CloudFront origin." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" parent="eWvkzI7JA3mnsKtQmJyP-1" vertex="1">
                    <mxGeometry x="1768" y="2843" width="280" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="WJwmBw8dlnYn9toBohla-3" value="&lt;font color=&quot;#ffffff&quot; style=&quot;font-size: 20px;&quot;&gt;6&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeColor=none;fillColor=#1badff;fontStyle=1" parent="eWvkzI7JA3mnsKtQmJyP-1" vertex="1">
                    <mxGeometry x="1721" y="2840" width="36" height="36" as="geometry"/>
                </mxCell>
                <mxCell id="31" value="&lt;font color=&quot;#ffffff&quot; style=&quot;font-size: 20px;&quot;&gt;12&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeColor=none;fillColor=#1badff;fontStyle=1" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
                    <mxGeometry x="1721" y="3231" width="36" height="36" as="geometry"/>
                </mxCell>
                <mxCell id="32" value="&lt;b&gt;SQS Queue&lt;/b&gt;&amp;nbsp;holds the messages in sequence until the lambda can process them.&amp;nbsp;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
                    <mxGeometry x="1766" y="3234" width="280" height="66" as="geometry"/>
                </mxCell>
                <mxCell id="33" value="&lt;b&gt;Container Based Lambda&lt;/b&gt;&amp;nbsp;deploys a handler from the Python app-lib/ to process the messages." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
