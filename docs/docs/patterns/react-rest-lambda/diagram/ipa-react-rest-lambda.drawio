        <mxCell id="yeEFA4pjfnQ1RmNaF71k-78" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;span style=&quot;line-height: 100%;&quot;&gt;7&lt;/span&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fontColor=#000000;strokeColor=none;fillColor=#1BADFF;gradientColor=none;align=center;verticalAlign=middle;fontSize=20;arcSize=49;spacing=0;spacingTop=0;fontStyle=1" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="983" y="2734" width="36" height="36" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-79" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;span style=&quot;line-height: 100%;&quot;&gt;6&lt;/span&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fontColor=#000000;strokeColor=none;fillColor=#1BADFF;gradientColor=none;align=center;verticalAlign=middle;fontSize=20;arcSize=50;spacing=0;spacingTop=0;fontStyle=1" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="809" y="3102" width="36" height="36" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-80" value="&lt;b&gt;Users&lt;/b&gt;&amp;nbsp;consume the web application from their browsers." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="1764" y="2551" width="280" height="82" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-81" value="&lt;h1&gt;ACME System - API Gateway REST Lambda&lt;/h1&gt;&lt;div&gt;&lt;p style=&quot;text-align: justify;&quot; data-pm-slice=&quot;1 1 []&quot;&gt;This pattern deploys a full-stack application with a React+Vite frontend on CloudFront/S3 connected to a REST API on Lambda behind API Gateway. The backend runs a FastAPI application in a container image served through Lambda Web Adapter, with DynamoDB as the data store and Titanic passenger records as demo data. A Cognito user pool provides OIDC authentication across the stack. The frontend is built once and configured at deploy time with a runtime config.js file that injects the API Gateway URL and Cognito settings — no rebuild needed if endpoints change. CloudFront distributes the SPA with OAC-secured S3 origin access. The API Gateway exposes both buffered CRUD routes and an optional streaming Lambda for Server-Sent Events. The pattern combines three sub-patterns — REST Lambda, CloudFront web client, and Cognito — wired together through CloudFormation stack outputs.&lt;/p&gt;&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="111" y="2188" width="932" height="151" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-82" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;span style=&quot;line-height: 100%;&quot;&gt;1&lt;/span&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fontColor=#000000;strokeColor=none;fillColor=#1BADFF;gradientColor=none;align=center;verticalAlign=middle;fontSize=20;arcSize=50;spacing=0;spacingTop=0;fontStyle=1" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="1720" y="2551" width="36" height="36" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-83" value="&lt;b&gt;React Single Page Application&lt;/b&gt;&amp;nbsp;delivers the application functionality. Application is written using Vite and Redux Toolkit for state management." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="1764" y="2635" width="280" height="82" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-84" value="&lt;b&gt;CloudFront&lt;/b&gt;&amp;nbsp;is the content delivery network, and delivers the app to edge endpoints for optimal performance worldwide." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="1764" y="2718" width="280" height="82" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-85" value="&lt;b&gt;API Gateway &lt;/b&gt;fronts the application and handled load balancing and the first level of authorization.&amp;nbsp;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="1764" y="2800" width="280" height="82" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-86" value="&lt;b&gt;Cognito&lt;/b&gt;&amp;nbsp;serves as the identity provider. The app references the Cognito service using a standard OIDC implementation, ready to be swapped out for a customer&#39;s OIDC compliant IdP." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="1766" y="2882" width="280" height="82" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-87" value="&lt;b&gt;Elastic Container Registry&lt;/b&gt;&amp;nbsp;holds container images for the container based Lambda compute." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="1766" y="2967" width="280" height="82" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-88" value="&lt;b&gt;Python app-lib/&lt;/b&gt;&amp;nbsp;is a pyproject.toml based library that offers a FastAPI REST interface with CRUD methods." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="1766" y="3051" width="280" height="82" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-89" value="&lt;b&gt;Buffered Lambda&lt;/b&gt;&amp;nbsp;delivers normal buffered responses for synchronous REST methods exposed using the Lambda Web Adapter." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="1766" y="3134" width="280" height="82" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-90" value="&lt;b&gt;Streaming Lambda&lt;/b&gt;&amp;nbsp;delivers SSE streaming methods for realtime client updates. The streaming lambda is also implemented using the Lambda Web Adapter." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="1766" y="3216" width="280" height="82" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-91" value="&lt;b style=&quot;border-color: rgb(218, 220, 224);&quot;&gt;DynamoDB Table&lt;/b&gt;&amp;nbsp;holds system data. High performance and scalable. Simple and secure." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
          <mxGeometry x="1768" y="3298" width="280" height="82" as="geometry" />
        </mxCell>
        <mxCell id="yeEFA4pjfnQ1RmNaF71k-92" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;span style=&quot;line-height: 100%;&quot;&gt;10&lt;/span&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fontColor=#000000;strokeColor=none;fillColor=#1BADFF;gradientColor=none;align=center;verticalAlign=middle;fontSize=20;arcSize=50;spacing=0;spacingTop=0;fontStyle=1" vertex="1" parent="eWvkzI7JA3mnsKtQmJyP-1">
