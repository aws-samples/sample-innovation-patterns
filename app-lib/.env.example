# app-lib environment variables
# Copy to .env and customize for local development.
# See: docs/docs/solution/app-lib/DOTENV.md

APP_REGION=us-east-1
APP_ENV=dev
APP_NAMESPACE=your-namespace-here

# CORS_ALLOWED_ORIGINS=*
# API_STAGE_PREFIX=

# --- Authentication (optional) ---
# AUTH_ENABLED=true
# AUTH_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX
# AUTH_AUDIENCE=your-cognito-client-id

# --- SQS Background Processing (optional) ---
# Required for job submission. Without this, the jobs endpoint returns 503.
# Get the URL from: get-stack-outputs --stack-name <namespace>-<env>-sqs
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/your-queue-name
